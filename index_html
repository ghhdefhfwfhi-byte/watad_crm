<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bait Al Nono CRM</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Quicksand:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#FFF8F4;
  --cream:#FFEEE3;
  --soft:#FFE0D0;
  --pink:#FF8FA3;
  --pink-deep:#E5638C;
  --rose:#F5A3B7;
  --mint:#A8DCC4;
  --sage:#C5E4D8;
  --warm:#FFB088;
  --brown:#8B5A3C;
  --text:#5D4037;
  --soft-text:#9E7A6B;
  --border:rgba(229,99,140,.18);
  --gap:2px;
  --green:#5BB987;
  --yellow:#F4B942;
  --purple:#B89BC9;
  --red:#E57373;
}
html,body{min-height:100%;background:var(--bg);color:var(--text);font-family:'Tajawal',sans-serif}

.screen{display:none;position:fixed;inset:0;z-index:900;align-items:center;justify-content:center;background:linear-gradient(135deg,#FFE0D0 0%,#FFF8F4 50%,#FFEEE3 100%);overflow-y:auto;padding:20px 0}
.screen.on{display:flex}

.box{background:#fff;border-top:4px solid var(--pink);width:460px;max-width:95vw;box-shadow:0 20px 50px rgba(229,99,140,.15);border-radius:16px;overflow:hidden}
.bh{padding:26px 28px 18px;border-bottom:1px solid var(--border);text-align:center;background:linear-gradient(180deg,#FFF8F4 0%,#fff 100%)}
.logo-wrap{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:6px}
.logo-icon{font-size:28px}
.logo{font-family:'Quicksand',sans-serif;font-size:24px;font-weight:700;letter-spacing:2px;color:var(--pink-deep)}
.logo-ar{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:800;color:var(--pink-deep);letter-spacing:2px;margin-top:2px}
.bsub{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--soft-text);text-transform:uppercase;margin-top:8px}
.bb{padding:24px 28px}
.step-block{background:var(--cream);padding:14px 16px;margin-bottom:12px;border-right:3px solid var(--pink);border-radius:8px}
.sn{font-size:8px;font-weight:700;letter-spacing:3px;color:var(--pink-deep);text-transform:uppercase;margin-bottom:6px}
.st{font-size:13px;font-weight:600;margin-bottom:4px;color:var(--text)}
.sd{font-size:11px;color:var(--soft-text);line-height:1.7}
.fl{font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--pink-deep);margin-bottom:5px;display:block}
.fi{width:100%;background:#fff;color:var(--text);border:1px solid var(--border);padding:10px 13px;font-family:'Tajawal',sans-serif;font-size:12px;outline:none;transition:.2s;margin-top:2px;border-radius:8px}
.fi:focus{border-color:var(--pink)}
.fi::placeholder{color:#C9B8AE}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
.fg{display:flex;flex-direction:column}
.fg.full{grid-column:1/-1}
.big-btn{width:100%;margin-top:14px;background:linear-gradient(135deg,#FF8FA3 0%,#E5638C 100%);color:#fff;border:none;padding:13px;font-family:'Tajawal',sans-serif;font-size:12px;font-weight:700;letter-spacing:3px;cursor:pointer;text-transform:uppercase;transition:.2s;border-radius:10px;box-shadow:0 4px 12px rgba(229,99,140,.25)}
.big-btn:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(229,99,140,.35)}
.err{font-size:11px;color:var(--red);margin-top:8px;min-height:16px;text-align:center;letter-spacing:1px}
.bf{padding:12px 28px;border-top:1px solid var(--border);font-size:10px;color:var(--soft-text);text-align:center;letter-spacing:2px;background:var(--cream)}

.login-box{background:#fff;border-top:4px solid var(--pink);width:380px;max-width:95vw;border-radius:16px;overflow:hidden;box-shadow:0 20px 50px rgba(229,99,140,.15)}
.name-inp{width:100%;background:#fff;color:var(--text);border:1px solid var(--border);padding:13px 16px;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;transition:.2s;border-radius:8px}
.name-inp:focus{border-color:var(--pink)}
.saved-users{display:flex;flex-direction:column;gap:6px;margin-top:8px;max-height:200px;overflow-y:auto}
.saved-user-btn{background:var(--cream);border:1px solid var(--border);color:var(--text);padding:10px 14px;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:.15s;text-align:left;border-radius:10px}
.saved-user-btn:hover{border-color:var(--pink);background:var(--soft)}
.role-badge{font-size:9px;font-weight:700;padding:3px 8px;border-radius:8px;letter-spacing:1px}
.r-admin{background:rgba(229,99,140,.15);color:var(--pink-deep)}
.r-manager{background:rgba(168,220,196,.4);color:#3a8d6a}
.r-viewer{background:rgba(184,155,201,.3);color:var(--purple)}
.online-pill{display:flex;align-items:center;justify-content:center;gap:7px;font-size:10px;color:var(--green);font-weight:700;letter-spacing:2px;margin-top:14px}
.pdot{width:7px;height:7px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.4)}}

#app{display:none;min-height:100vh;flex-direction:column;background:var(--bg)}
#app.on{display:flex}

.header{background:linear-gradient(180deg,#fff 0%,#FFF8F4 100%);border-bottom:2px solid var(--pink);padding:0 22px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;flex-shrink:0;gap:12px;box-shadow:0 2px 12px rgba(229,99,140,.08)}
.hlogo{display:flex;align-items:center;gap:8px;flex-shrink:0}
.hlogo-icon{font-size:20px}
.hlogo-text{font-family:'Quicksand',sans-serif;font-size:18px;font-weight:700;letter-spacing:2px;color:var(--pink-deep)}
.hmid{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
.sync-badge{font-size:9px;font-weight:700;letter-spacing:2px;padding:4px 10px;border-radius:8px;display:flex;align-items:center;gap:5px;flex-shrink:0}
.sb-live{background:rgba(91,185,135,.15);color:var(--green)}
.sb-con{background:rgba(244,185,66,.15);color:var(--yellow)}
.sb-off{background:rgba(229,115,115,.15);color:var(--red)}
.sdot{width:5px;height:5px;border-radius:50%;background:currentColor}
.sb-live .sdot{animation:pulse 1.5s infinite}
.online-avs{display:flex;gap:4px;flex-wrap:wrap}
.oav{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;border:2px solid #fff;position:relative;flex-shrink:0;box-shadow:0 2px 4px rgba(229,99,140,.2)}
.oav::after{content:'';position:absolute;bottom:-1px;right:-1px;width:8px;height:8px;background:var(--green);border-radius:50%;border:2px solid #fff}
.hright{display:flex;align-items:center;gap:8px;flex-shrink:0}
.user-chip{display:flex;align-items:center;gap:8px;background:var(--cream);padding:6px 12px;border-radius:10px;border:1px solid var(--border)}
.user-av{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff}
.user-meta{display:flex;flex-direction:column;line-height:1.2}
.user-name{font-size:11px;font-weight:700;letter-spacing:1px;color:var(--text)}
.user-role{font-size:8px;letter-spacing:1px;font-weight:700;margin-top:2px}
.hbtn{padding:7px 14px;font-family:'Tajawal',sans-serif;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;border-radius:8px;transition:.15s;white-space:nowrap}
.hbtn-add{background:linear-gradient(135deg,#FF8FA3 0%,#E5638C 100%);color:#fff;border:none;box-shadow:0 2px 8px rgba(229,99,140,.25)}
.hbtn-add:hover{box-shadow:0 4px 12px rgba(229,99,140,.4)}
.hbtn-users{background:#fff;border:1px solid var(--pink);color:var(--pink-deep)}.hbtn-users:hover{background:var(--pink);color:#fff}
.hbtn-out{background:#fff;border:1px solid var(--border);color:var(--soft-text)}.hbtn-out:hover{border-color:var(--red);color:var(--red)}

.controls{background:#fff;border-bottom:1px solid var(--border);padding:10px 22px;display:flex;align-items:center;gap:12px;flex-shrink:0;flex-wrap:wrap}
.clbl{font-size:9px;font-weight:700;letter-spacing:3px;color:var(--pink-deep);text-transform:uppercase;white-space:nowrap}
.csep{width:1px;height:16px;background:var(--border)}
select{background:#fff;color:var(--text);border:1px solid var(--border);padding:6px 10px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:11px;outline:none;cursor:pointer;min-width:90px;font-weight:600}
select:hover{border-color:var(--pink)}
.srch{background:#fff;color:var(--text);border:1px solid var(--border);padding:6px 12px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:11px;outline:none;width:200px}
.srch:focus{border-color:var(--pink)}
.reset-btn{background:#fff;border:1px solid var(--red);color:var(--red);padding:6px 12px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:10px;font-weight:700;cursor:pointer;letter-spacing:1px;margin-left:auto}
.reset-btn:hover{background:var(--red);color:#fff}

.body{padding:18px 22px;flex:1}
.sec{font-size:9px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--pink-deep);display:flex;align-items:center;gap:10px;margin:14px 0 10px}
.sec::before{content:'🍼';font-size:11px}
.sec::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--pink) 0%,transparent 100%);opacity:.3}

.krow{display:grid;grid-template-columns:repeat(8,1fr);gap:var(--gap);margin-bottom:var(--gap)}
.kpi{background:#fff;padding:14px 16px;cursor:pointer;transition:.2s;border:1px solid var(--border);border-radius:12px;position:relative;overflow:hidden}
.kpi:hover{background:var(--cream);transform:translateY(-1px)}
.kpi.hi{background:linear-gradient(135deg,#FF8FA3 0%,#E5638C 100%);color:#fff;border-color:transparent}
.kpi.hi:hover{background:linear-gradient(135deg,#FFA0B5 0%,#E76A95 100%)}
.kpi.active{outline:2px solid var(--pink);outline-offset:-1px}
.kl{font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--soft-text);margin-bottom:5px}
.kpi.hi .kl{color:rgba(255,255,255,.85)}
.kv{font-size:22px;font-weight:900;font-family:'DM Mono',monospace;color:var(--text)}
.kpi.hi .kv{color:#fff}

.pipeline{display:grid;grid-template-columns:repeat(5,1fr);gap:var(--gap);margin-bottom:var(--gap)}
.stage{background:#fff;padding:13px 14px;border-top:3px solid;cursor:pointer;transition:.2s;border-radius:0 0 12px 12px}
.stage:hover{background:var(--cream);transform:translateY(-1px)}
.stage.active{background:var(--cream)}
.stage[data-s=new]{border-color:#74AADD}.stage[data-s=contacted]{border-color:var(--yellow)}
.stage[data-s=qualified]{border-color:var(--purple)}.stage[data-s=negotiation]{border-color:var(--warm)}
.stage[data-s=closed]{border-color:var(--green)}
.sl{font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:5px}
.stage[data-s=new] .sl{color:#74AADD}.stage[data-s=contacted] .sl{color:#D49A1F}
.stage[data-s=qualified] .sl{color:var(--purple)}.stage[data-s=negotiation] .sl{color:var(--warm)}
.stage[data-s=closed] .sl{color:var(--green)}
.sc{font-size:26px;font-weight:900;font-family:'DM Mono',monospace;color:var(--text)}
.sbar{height:3px;border-radius:2px;margin-top:7px;opacity:.5;transition:.6s}

.feed{background:#fff;padding:10px 16px;margin-bottom:var(--gap);display:flex;align-items:center;gap:10px;overflow:hidden;border-left:3px solid var(--pink);border-radius:8px;border:1px solid var(--border)}
.fdot{width:6px;height:6px;background:var(--pink);border-radius:50%;flex-shrink:0;animation:pulse 1.5s infinite}
.flbl{font-size:8px;font-weight:700;letter-spacing:3px;color:var(--pink-deep);text-transform:uppercase;flex-shrink:0}
.ftxt{font-size:11px;color:var(--soft-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;font-weight:500}

.tbl-wrap{background:#fff;padding:16px 20px;overflow-x:auto;border:1px solid var(--border);border-radius:12px;box-shadow:0 2px 12px rgba(229,99,140,.05)}
.tbl-info{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px}
.tbl-count{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--soft-text)}
.tbl-count strong{color:var(--pink-deep);font-size:14px;font-weight:900}
table{width:100%;border-collapse:collapse;min-width:960px}
th{font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--pink-deep);text-align:left;padding:10px 10px;border-bottom:2px solid var(--border)}
td{font-size:11px;color:var(--text);text-align:left;padding:9px 10px;border-bottom:1px solid rgba(229,99,140,.06);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--cream)}
.pill{display:inline-block;padding:3px 9px;border-radius:8px;font-size:9px;font-weight:700;letter-spacing:1px}
.p-new{background:rgba(116,170,221,.2);color:#5A8AB8}.p-contacted{background:rgba(244,185,66,.18);color:#D49A1F}
.p-qualified{background:rgba(184,155,201,.25);color:var(--purple)}.p-negotiation{background:rgba(255,176,136,.25);color:#D17B4F}
.p-closed{background:rgba(91,185,135,.18);color:var(--green)}.p-lost{background:rgba(229,115,115,.18);color:var(--red)}
.sdot2{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:5px;vertical-align:middle}
.av-sm{width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;margin-right:7px;vertical-align:middle;flex-shrink:0;box-shadow:0 2px 4px rgba(229,99,140,.15)}
.product-tag{display:inline-block;padding:2px 8px;background:var(--cream);color:var(--pink-deep);border-radius:6px;font-size:10px;font-weight:600;border:1px solid var(--border)}
.by-wrap{display:flex;align-items:center;gap:5px}
.by-av{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:700;color:#fff;flex-shrink:0}
.soc-a{display:inline-block;padding:2px 7px;border-radius:6px;font-size:9px;font-weight:700;text-decoration:none;border:1px solid var(--border);color:var(--soft-text);margin-right:3px;transition:.15s}
.soc-a:hover{border-color:var(--pink);color:var(--pink-deep);background:var(--cream)}
.abtn{background:#fff;border:1px solid;padding:4px 10px;border-radius:6px;font-family:'Tajawal',sans-serif;font-size:9px;font-weight:700;cursor:pointer;letter-spacing:1px;transition:.15s}
.be{border-color:var(--yellow);color:#D49A1F}.be:hover{background:var(--yellow);color:#fff}
.bd{border-color:var(--red);color:var(--red)}.bd:hover{background:var(--red);color:#fff}
.bv{border-color:var(--pink);color:var(--pink-deep)}.bv:hover{background:var(--pink);color:#fff}
.empty-row{text-align:center;padding:50px 20px;color:var(--soft-text)}
.empty-icon{font-size:36px;margin-bottom:10px}
.empty-row p{font-size:13px;letter-spacing:1px;line-height:1.8}

.overlay{display:none;position:fixed;inset:0;background:rgba(93,64,55,.5);backdrop-filter:blur(4px);z-index:300;align-items:center;justify-content:center;padding:20px}
.overlay.on{display:flex}
.modal{background:#fff;width:600px;max-width:96vw;max-height:90vh;overflow-y:auto;border-top:4px solid var(--pink);border-radius:16px;box-shadow:0 20px 60px rgba(229,99,140,.3)}
.mh{padding:16px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:var(--cream)}
.mt{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--pink-deep)}
.mclose{background:transparent;border:none;color:var(--soft-text);font-size:18px;cursor:pointer;width:24px;height:24px;display:flex;align-items:center;justify-content:center}.mclose:hover{color:var(--pink-deep)}
.mbody{padding:22px}
.mfoot{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;align-items:center;background:var(--cream)}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg2 .fgr{display:flex;flex-direction:column;gap:4px}
.fg2 .fgr.full{grid-column:1/-1}
.fdiv{grid-column:1/-1;font-size:8px;font-weight:700;letter-spacing:3px;color:var(--pink-deep);text-transform:uppercase;padding-top:8px;border-top:1px solid var(--border);margin-top:4px}
.fs2{background:#fff;color:var(--text);border:1px solid var(--border);padding:9px 12px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:12px;outline:none;width:100%;transition:.2s;cursor:pointer;font-weight:500}
.fs2:focus{border-color:var(--pink)}
.soc2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px}
.sw{display:flex;flex-direction:column;gap:3px}
.slbl{font-size:8px;font-weight:700;letter-spacing:2px;color:var(--soft-text);text-transform:uppercase}
.bsave{background:linear-gradient(135deg,#FF8FA3 0%,#E5638C 100%);color:#fff;border:none;padding:10px 24px;font-family:'Tajawal',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;cursor:pointer;border-radius:8px;box-shadow:0 2px 8px rgba(229,99,140,.25)}
.bsave:hover{box-shadow:0 4px 12px rgba(229,99,140,.4)}
.bsave:disabled{opacity:.5;cursor:not-allowed}
.bcancel{background:#fff;border:1px solid var(--border);color:var(--soft-text);padding:10px 18px;font-family:'Tajawal',sans-serif;font-size:11px;font-weight:700;cursor:pointer;border-radius:8px}
.bcancel:hover{border-color:var(--text);color:var(--text)}
.spin{display:none;font-size:10px;color:#D49A1F;letter-spacing:1px;align-items:center;gap:5px;margin-right:auto}
.spin.on{display:flex}

.users-modal{width:520px}
.user-row{display:flex;align-items:center;justify-content:space-between;padding:13px 0;border-bottom:1px solid rgba(229,99,140,.08);gap:8px;flex-wrap:wrap}
.user-row:last-child{border-bottom:none}
.user-info{display:flex;align-items:center;gap:12px}
.user-av-lg{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;position:relative;box-shadow:0 2px 6px rgba(229,99,140,.2)}
.user-av-lg.online::after{content:'';position:absolute;bottom:0;right:0;width:11px;height:11px;background:var(--green);border-radius:50%;border:2px solid #fff}
.user-nm{font-size:13px;font-weight:700;color:var(--text)}
.user-mt{font-size:10px;color:var(--soft-text);margin-top:3px;letter-spacing:1px}
.role-select{background:#fff;color:var(--text);border:1px solid var(--border);padding:5px 10px;border-radius:6px;font-family:'Tajawal',sans-serif;font-size:11px;outline:none;cursor:pointer;font-weight:600}
.role-select:hover{border-color:var(--pink)}
.new-user-form{background:var(--cream);padding:16px;margin-top:14px;border-top:2px solid var(--pink);border-radius:12px}
.new-user-title{font-size:10px;color:var(--pink-deep);letter-spacing:2px;font-weight:700;margin-bottom:12px}

.toast-wrap{position:fixed;top:70px;right:14px;z-index:600;display:flex;flex-direction:column;gap:7px;pointer-events:none}
.toast{background:#fff;border-right:3px solid var(--pink);padding:11px 15px;font-size:11px;font-weight:600;letter-spacing:1px;animation:tIn .3s ease;max-width:280px;box-shadow:0 6px 16px rgba(229,99,140,.15);border-radius:8px;color:var(--text)}
.toast.ok{border-color:var(--green)}.toast.err{border-color:var(--red)}
@keyframes tIn{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}

.footer{background:#fff;border-top:1px solid var(--border);padding:0 22px;height:34px;display:flex;align-items:center;justify-content:space-between;font-size:9px;color:var(--soft-text);flex-shrink:0;letter-spacing:1px}
.fbrand{font-family:'Quicksand',sans-serif;font-weight:700;letter-spacing:3px;color:var(--pink-deep)}

@media(max-width:1100px){.krow{grid-template-columns:repeat(4,1fr)}.pipeline{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){.krow{grid-template-columns:repeat(2,1fr)}.pipeline{grid-template-columns:repeat(2,1fr)}.header{flex-wrap:wrap;height:auto;padding:8px 14px}.body{padding:12px 14px}}
</style>
</head>
<body>

<div class="screen" id="setupScreen">
  <div class="box">
    <div class="bh">
