<script>
const CFG_KEY='nono_cfg_v1',USER_KEY='nono_user_v1';
const FIREBASE_CFG={
  databaseURL:'https://bait-al-nono-default-rtdb.firebaseio.com',
  projectId:'bait-al-nono',
  authDomain:'bait-al-nono.firebaseapp.com'
};
const UC=['#FF8FA3','#74AADD','#B89BC9','#5BB987','#F4B942','#FFB088','#E5638C','#A8DCC4'];
const ucMap={};
const srcCol={meta:'#1877F2',instagram:'#E1306C',tiktok:'#69C9D0',whatsapp:'#25D366',referral:'#B89BC9',walk_in:'#FFB088'};
const stPill={new:'pill p-new',contacted:'pill p-contacted',qualified:'pill p-qualified',negotiation:'pill p-negotiation',closed:'pill p-closed',lost:'pill p-lost'};
const stLabel={new:'New',contacted:'Contacted',qualified:'Qualified',negotiation:'Negotiation',closed:'Closed',lost:'Lost'};
const productLabel={
  clothes:'👕 Clothes',
  furniture:'🛏️ Furniture',
  strollers:'🚼 Strollers',
  toys:'🧸 Toys',
  bedding:'🛌 Bedding',
  feeding:'🍼 Feeding',
  bath:'🛁 Bath',
  gift_set:'🎁 Gift Set',
  other:'📦 Other'
};

let db,leadsRef,usersRef,presenceRef,feedRef;
let currentUser=null,leads={},users={},onlinePresence={},presInt=null;

function uc(name){if(!ucMap[name]){ucMap[name]=UC[Object.keys(ucMap).length%UC.length];}return ucMap[name];}
function loadCfg(){try{return JSON.parse(localStorage.getItem(CFG_KEY));}catch{return null;}}
function saveCfg(c){localStorage.setItem(CFG_KEY,JSON.stringify(c));}
function loadUser(){try{return JSON.parse(localStorage.getItem(USER_KEY));}catch{return null;}}
function saveUser(u){localStorage.setItem(USER_KEY,JSON.stringify(u));}
function clearUser(){localStorage.removeItem(USER_KEY);}
function slugify(s){return String(s||'').toLowerCase().trim().replace(/[^a-z0-9]/g,'_');}
function esc(s){return String(s||'').replace(/[<>"']/g,c=>({'<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function show(id){document.getElementById(id).classList.add('on');}
function hide(id){document.getElementById(id).classList.remove('on');}
function g(id){const e=document.getElementById(id);return e?e.value:'';}
function sv(id,val){const e=document.getElementById(id);if(e)e.value=val||'';}
function se(id,txt){const e=document.getElementById(id);if(e)e.textContent=txt||'';}

function initFirebase(cfg){
  if(!firebase.apps.length) firebase.initializeApp(cfg);
  db=firebase.database();
  leadsRef=db.ref('leads');
  usersRef=db.ref('users');
  presenceRef=db.ref('presence');
  feedRef=db.ref('feed');
}

async function doSetup(){
  const cfg=FIREBASE_CFG;
  const name=g('cfgName').trim(),pass=g('cfgPass').trim();
  if(!name){se('setupErr','Your name is required');return;}
  if(!pass||pass.length<4){se('setupErr','Password must be at least 4 characters');return;}
  try{
    initFirebase(cfg);
    const slug=slugify(name);
    const snap=await usersRef.child(slug).get();
    if(!snap.exists()){
      await usersRef.child(slug).set({name,role:'admin',pass:btoa(pass),createdAt:Date.now()});
    }
    saveCfg(cfg);
    toast('Setup complete!','ok');
    showLogin();
  }catch(e){
    const denied=/permission|denied/i.test(e.message||'');
    se('setupErr', denied
      ? '⚠️ Permission denied — انشر قواعد Firebase (Publish) بعدين جرّب.'
      : ('Firebase error: '+e.message));
  }
}

function showLogin(){hide('setupScreen');show('loginScreen');loadSavedUsers();}

async function loadSavedUsers(){
  try{
    const snap=await usersRef.get();
    const wrap=document.getElementById('savedUsersWrap');
    if(!snap.exists()){wrap.style.display='none';return;}
    const all=Object.values(snap.val());
    if(all.length>0){
      wrap.style.display='block';
      document.getElementById('savedUsersList').innerHTML=all.map(u=>`
        <button class="saved-user-btn" onclick="quickLogin('${esc(u.name).replace(/'/g,'&apos;')}')">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:32px;height:32px;border-radius:50%;background:${uc(u.name)};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff">${u.name.slice(0,2).toUpperCase()}</div>
            <span>${esc(u.name)}</span>
          </div>
          <span class="role-badge r-${u.role}">${u.role.toUpperCase()}</span>
        </button>`).join('');
    } else wrap.style.display='none';
  }catch(e){console.error(e);}
}

function quickLogin(name){
  const decoded=name.replace(/&apos;/g,"'");
  document.getElementById('loginName').value=decoded;
  document.getElementById('loginPass').focus();
}

async function doLogin(){
  const name=g('loginName').trim(),pass=g('loginPass').trim();
  if(!name){se('loginErr','Enter your name');return;}
  if(!pass){se('loginErr','Enter your password');return;}
  try{
    const snap=await usersRef.child(slugify(name)).get();
    if(!snap.exists()){se('loginErr','User not found. Ask admin to add you.');return;}
    const u=snap.val();
    if(atob(u.pass||'')!==pass){se('loginErr','Wrong password');return;}
    currentUser={name:u.name,role:u.role,color:uc(u.name),slug:slugify(u.name)};
    saveUser(currentUser);
    se('loginErr','');
    hide('loginScreen');
    launchApp();
  }catch(e){
    const denied=/permission|denied/i.test(e.message||'');
    se('loginErr', denied
      ? '⚠️ القواعد مو منشورة — افتح Firebase → Rules واضغط Publish'
      : ('Error: '+e.message));
  }
}

function doLogout(){
  if(presInt)clearInterval(presInt);
  if(presenceRef&&currentUser)presenceRef.child(currentUser.slug).remove();
  if(leadsRef)leadsRef.off();
  if(usersRef)usersRef.off();
  if(presenceRef)presenceRef.off();
  if(feedRef)feedRef.off();
  currentUser=null;clearUser();
  leads={};users={};onlinePresence={};
  document.getElementById('app').classList.remove('on');
  document.getElementById('loginPass').value='';
  se('loginErr','');
  show('loginScreen');
  loadSavedUsers();
}

function launchApp(){
  document.getElementById('app').classList.add('on');
  const av=document.getElementById('headerAv');
  av.style.background=currentUser.color;
  av.textContent=currentUser.name.slice(0,2).toUpperCase();
  document.getElementById('headerName').textContent=currentUser.name.toUpperCase();
  const rEl=document.getElementById('headerRole');
  const rColors={admin:'var(--pink-deep)',manager:'var(--green)',viewer:'var(--purple)'};
  rEl.textContent=currentUser.role.toUpperCase();
  rEl.style.color=rColors[currentUser.role]||'var(--text)';
  document.getElementById('btnUsers').style.display=currentUser.role==='admin'?'':'none';
  document.getElementById('btnAdd').style.display=currentUser.role!=='viewer'?'':'none';
  startListeners();
  startPresence();
}

function startListeners(){
  setSyncBadge('con','CONNECTING');
  leadsRef.on('value',snap=>{
    const prevIds=new Set(Object.keys(leads));
    leads=snap.val()||{};
    Object.keys(leads).forEach(id=>{
      if(!prevIds.has(id)&&leads[id].addedBy!==currentUser.name){
        toast(`${leads[id].addedBy} added: ${leads[id].name}`,'ok');
      }
    });
    renderAll();
    setSyncBadge('live','LIVE');
    document.getElementById('footTxt').textContent='Last sync: '+new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  },err=>{setSyncBadge('off','OFFLINE');toast('Connection: '+err.message,'err');});
  
  usersRef.on('value',snap=>{users=snap.val()||{};renderUsersList();});
  presenceRef.on('value',snap=>{onlinePresence=snap.val()||{};renderOnline();renderUsersList();});
  feedRef.limitToLast(1).on('child_added',snap=>{
    const m=snap.val();
    if(m&&m.text)document.getElementById('feedTxt').textContent=m.text;
  });
}

async function pushFeed(text){
  if(!feedRef)return;
  try{await feedRef.push({text:`[${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}] ${text}`,ts:Date.now()});}catch{}
}

function startPresence(){
  const update=()=>{if(presenceRef&&currentUser)presenceRef.child(currentUser.slug).set({name:currentUser.name,role:currentUser.role,ts:Date.now()});};
  update();
  presInt=setInterval(update,8000);
  if(presenceRef&&currentUser)presenceRef.child(currentUser.slug).onDisconnect().remove();
}

function renderAll(){
  const arr=Object.values(leads);
  document.getElementById('totalCount').textContent=arr.length;
  updateKPIs(arr);
  updatePipeline(arr);
  updateUserFilter(arr);
  renderTable();
}

function updateKPIs(arr){
  document.getElementById('k0').textContent=arr.length;
  ['new','contacted','qualified','negotiation','closed','lost'].forEach((s,i)=>{
    document.getElementById('k'+(i+1)).textContent=arr.filter(l=>l.status===s).length;
  });
  const closed=arr.filter(l=>l.status==='closed').length;
  document.getElementById('k7').textContent=arr.length?Math.round(closed/arr.length*100)+'%':'0%';
}

function updatePipeline(arr){
  const stages=['new','contacted','qualified','negotiation','closed'];
  const counts=stages.map(s=>arr.filter(l=>l.status===s).length);
  const mx=Math.max(...counts,1);
  counts.forEach((c,i)=>{
    document.getElementById('ps'+i).textContent=c;
    document.getElementById('pb'+i).style.width=Math.round(c/mx*100)+'%';
  });
  const cur=g('fSt');
  document.querySelectorAll('.stage').forEach(s=>s.classList.toggle('active',s.dataset.s===cur));
}

function getFiltered(){
  const st=g('fSt')||'all',src=g('fSrc')||'all',prod=g('fProd')||'all',by=g('fBy')||'all';
  const q=(g('fQ')||'').toLowerCase().trim();
  return Object.values(leads).filter(l=>{
    if(st!=='all'&&l.status!==st)return false;
    if(src!=='all'&&l.source!==src)return false;
    if(prod!=='all'&&l.product!==prod)return false;
    if(by!=='all'&&l.addedBy!==by)return false;
    if(q){
      const hay=[l.name,l.phone,l.notes,l.productDetails,l.addedBy].filter(Boolean).join(' ').toLowerCase();
      if(!hay.includes(q))return false;
    }
    return true;
  }).sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
}

function renderTable(){
  const data=getFiltered();
  const tbody=document.getElementById('leadsBody');
  document.getElementById('visibleCount').textContent=data.length;
  
  const st=g('fSt'),src=g('fSrc'),prod=g('fProd'),q=g('fQ'),by=g('fBy');
  const f=[];
  if(st!=='all')f.push(`Status: ${stLabel[st]||st}`);
  if(src!=='all')f.push(`Source: ${src}`);
  if(prod!=='all')f.push(`Product: ${productLabel[prod]||prod}`);
  if(by!=='all')f.push(`By: ${by}`);
  if(q)f.push(`"${q}"`);
  document.getElementById('filterStatus').textContent=f.length?'🍼 '+f.join(' · '):'';
  
  if(!data.length){
    const total=Object.keys(leads).length;
    if(total===0){
      tbody.innerHTML=`<tr><td colspan="10"><div class="empty-row"><div class="empty-icon">🍼</div><p>No customers yet.<br>Click <strong style="color:var(--pink-deep)">+ ADD CUSTOMER</strong> to start.</p></div></td></tr>`;
    } else {
      tbody.innerHTML=`<tr><td colspan="10"><div class="empty-row"><div class="empty-icon">🔍</div><p>No customers match your filters.<br><br><button class="abtn bv" onclick="resetFilters()">CLEAR FILTERS</button></p></div></td></tr>`;
    }
    document.querySelectorAll('.kpi').forEach(k=>k.classList.remove('active'));
    return;
  }
  
  const today=new Date().toISOString().split('T')[0];
  const canEdit=currentUser.role!=='viewer';
  
  tbody.innerHTML=data.map(l=>{
    const init=(l.name||'?').split(' ').slice(0,2).map(w=>(w[0]||'')).join('').toUpperCase();
    const fuColor=l.followup?(l.followup<today?'var(--red)':l.followup===today?'#D49A1F':'var(--text)'):'#C9B8AE';
    const soc=[
      l.ig&&`<a class="soc-a" href="${esc(l.ig)}" target="_blank" rel="noopener">IG</a>`,
      l.fb&&`<a class="soc-a" href="${esc(l.fb)}" target="_blank" rel="noopener">FB</a>`,
      l.tt&&`<a class="soc-a" href="${esc(l.tt)}" target="_blank" rel="noopener">TT</a>`,
      l.wa&&`<a class="soc-a" href="${esc(l.wa)}" target="_blank" rel="noopener" style="color:var(--green);border-color:rgba(91,185,135,.4)">WA</a>`,
      l.sn&&`<a class="soc-a" href="${esc(l.sn)}" target="_blank" rel="noopener">SC</a>`,
      l.ot&&`<a class="soc-a" href="${esc(l.ot)}" target="_blank" rel="noopener">🔗</a>`
    ].filter(Boolean).join('');
    const byColor=uc(l.addedBy||'?');
    const canDel=currentUser.role==='admin'||(currentUser.role==='manager'&&l.addedBy===currentUser.name);
    const productDisplay=l.product?`<span class="product-tag">${productLabel[l.product]||esc(l.product)}</span>${l.productDetails?`<div style="font-size:9px;color:var(--soft-text);margin-top:3px">${esc(l.productDetails)}</div>`:''}`:'<span style="color:#C9B8AE;font-size:10px">—</span>';
    return `<tr>
      <td><span class="av-sm" style="background:${srcCol[l.source]||'#999'}">${init}</span><span style="font-weight:700">${esc(l.name||'—')}</span>${l.budget?`<div style="font-size:9px;color:var(--green);font-weight:700;margin-top:2px;margin-right:38px">${esc(l.budget)}</div>`:''}</td>
      <td style="font-family:'DM Mono',monospace;font-size:10px">${esc(l.phone||'—')}</td>
      <td>${productDisplay}</td>
      <td><span class="sdot2" style="background:${srcCol[l.source]||'#888'}"></span>${esc(l.source||'—')}</td>
      <td><span class="${stPill[l.status]||'pill'}">${stLabel[l.status]||esc(l.status||'—')}</span></td>
      <td style="font-size:10px;color:${fuColor};font-weight:600">${esc(l.followup||'—')}</td>
      <td>${soc||'<span style="color:#C9B8AE;font-size:9px">—</span>'}</td>
      <td style="font-size:10px;color:var(--soft-text);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${esc(l.notes||'')}">${esc(l.notes||'—')}</td>
      <td><div class="by-wrap"><div class="by-av" style="background:${byColor}">${(l.addedBy||'?').slice(0,2).toUpperCase()}</div><span style="font-size:10px;font-weight:700">${esc(l.addedBy||'?')}</span></div></td>
      <td><div style="display:flex;gap:4px;flex-wrap:wrap">
        ${canEdit?`<button class="abtn be" onclick="editLead('${l.id}')">EDIT</button>`:''}
        ${canDel?`<button class="abtn bd" onclick="deleteLead('${l.id}')">DEL</button>`:''}
      </div></td>
    </tr>`;
  }).join('');
  
  document.querySelectorAll('.kpi').forEach(k=>k.classList.remove('active'));
  const sIdx=['all','new','contacted','qualified','negotiation','closed','lost'].indexOf(st);
  if(sIdx>=0){
    const kpis=document.querySelectorAll('.kpi');
    if(kpis[sIdx])kpis[sIdx].classList.add('active');
  }
}

function renderOnline(){
  const cutoff=Date.now()-25000;
  const active=Object.values(onlinePresence).filter(u=>u.ts>cutoff);
  document.getElementById('onlineAvs').innerHTML=active.map(u=>
    `<div class="oav" style="background:${uc(u.name)}" title="${esc(u.name)} (${u.role}) — online">${u.name.slice(0,2).toUpperCase()}</div>`
  ).join('');
}

function renderUsersList(){
  if(!currentUser||currentUser.role!=='admin')return;
  const list=document.getElementById('usersList');
  if(!list)return;
  const all=Object.values(users);
  const cutoff=Date.now()-25000;
  list.innerHTML=all.map(u=>{
    const isOnline=Object.values(onlinePresence).some(p=>p.name===u.name&&p.ts>cutoff);
    const slug=slugify(u.name);
    return `<div class="user-row">
      <div class="user-info">
        <div class="user-av-lg ${isOnline?'online':''}" style="background:${uc(u.name)}">${u.name.slice(0,2).toUpperCase()}</div>
        <div>
          <div class="user-nm">${esc(u.name)} ${u.name===currentUser.name?'<span style="color:var(--pink-deep);font-size:10px">(you)</span>':''}</div>
          <div class="user-mt">${u.role.toUpperCase()} · ${isOnline?'<span style="color:var(--green)">● ONLINE</span>':'OFFLINE'}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        ${u.name!==currentUser.name?`
          <select class="role-select" onchange="changeRole('${slug}','${esc(u.name).replace(/'/g,'&apos;')}',this.value)">
            <option value="admin"${u.role==='admin'?' selected':''}>Admin</option>
            <option value="manager"${u.role==='manager'?' selected':''}>Manager</option>
            <option value="viewer"${u.role==='viewer'?' selected':''}>Viewer</option>
          </select>
          <button class="abtn bd" onclick="removeUser('${slug}','${esc(u.name).replace(/'/g,'&apos;')}')">REMOVE</button>
        `:`<span class="role-badge r-${u.role}">${u.role.toUpperCase()}</span>`}
      </div>
    </div>`;
  }).join('');
}

function updateUserFilter(arr){
  const sel=document.getElementById('fBy');
  const cur=sel.value;
  const names=[...new Set(arr.map(l=>l.addedBy).filter(Boolean))];
  sel.innerHTML='<option value="all">Everyone</option>'+names.map(n=>`<option value="${esc(n)}"${cur===n?' selected':''}>${esc(n)}</option>`).join('');
}

function setStatusFilter(s){
  document.getElementById('fSt').value=s;
  renderTable();
  updatePipeline(Object.values(leads));
}

function resetFilters(){
  document.getElementById('fSt').value='all';
  document.getElementById('fSrc').value='all';
  document.getElementById('fProd').value='all';
  document.getElementById('fBy').value='all';
  document.getElementById('fQ').value='';
  renderTable();
  updatePipeline(Object.values(leads));
  toast('Filters cleared','ok');
}

function openLeadModal(editId=null){
  if(currentUser.role==='viewer'){toast('Viewers cannot add customers','err');return;}
  document.getElementById('editId').value=editId||'';
  document.getElementById('leadModalTitle').textContent=editId?'✎ EDIT CUSTOMER':'+ ADD NEW CUSTOMER';
  if(editId&&leads[editId]){
    const l=leads[editId];
    sv('fName',l.name);sv('fPhone',l.phone);
    sv('fProduct',l.product||'');sv('fProductDetails',l.productDetails);
    sv('fSource',l.source||'instagram');sv('fStatus',l.status||'new');
    sv('fFu',l.followup);sv('fBudget',l.budget);sv('fNotes',l.notes);
    sv('sFb',l.fb);sv('sIg',l.ig);sv('sTt',l.tt);sv('sWa',l.wa);sv('sSn',l.sn);sv('sOt',l.ot);
  } else {
    ['fName','fPhone','fProductDetails','fFu','fBudget','fNotes','sFb','sIg','sTt','sWa','sSn','sOt'].forEach(id=>{
      const e=document.getElementById(id);if(e)e.value='';
    });
    sv('fProduct','');sv('fSource','instagram');sv('fStatus','new');
  }
  document.getElementById('leadModal').classList.add('on');
}

function closeModal(id){document.getElementById(id).classList.remove('on');}
function editLead(id){openLeadModal(id);}

async function saveLead(){
  const name=g('fName').trim();
  if(!name){toast('Customer name is required','err');return;}
  const editId=g('editId');
  document.getElementById('saveSpin').classList.add('on');
  document.getElementById('saveBtn').disabled=true;
  const id=editId||leadsRef.push().key;
  const lead={id,name,
    phone:g('fPhone').trim(),
    product:g('fProduct'),
    productDetails:g('fProductDetails').trim(),
    source:g('fSource'),status:g('fStatus'),
    followup:g('fFu'),budget:g('fBudget').trim(),notes:g('fNotes').trim(),
    fb:g('sFb').trim(),ig:g('sIg').trim(),tt:g('sTt').trim(),wa:g('sWa').trim(),sn:g('sSn').trim(),ot:g('sOt').trim(),
    addedBy:currentUser.name,
    createdAt:editId?(leads[editId]?.createdAt||Date.now()):Date.now(),
    updatedAt:Date.now()};
  try{
    await leadsRef.child(id).set(lead);
    await pushFeed(`${currentUser.name} ${editId?'updated':'added'} "${name}"`);
    toast(`${editId?'Updated':'Added'}: ${name}`,'ok');
    closeModal('leadModal');
  }catch(e){toast('Save failed: '+e.message,'err');}
  document.getElementById('saveSpin').classList.remove('on');
  document.getElementById('saveBtn').disabled=false;
}

async function deleteLead(id){
  const l=leads[id];
  if(!l||!confirm(`Delete "${l.name}"?`))return;
  try{
    await leadsRef.child(id).remove();
    await pushFeed(`${currentUser.name} deleted "${l.name}"`);
    toast(`Deleted: ${l.name}`,'err');
  }catch(e){toast('Delete failed: '+e.message,'err');}
}

function openUsers(){renderUsersList();document.getElementById('usersModal').classList.add('on');}

async function addUser(){
  const name=g('newUserName').trim(),pass=g('newUserPass').trim(),role=g('newUserRole');
  if(!name){se('addUserErr','Name required');return;}
  if(!pass||pass.length<4){se('addUserErr','Password min 4 chars');return;}
  const slug=slugify(name);
  const snap=await usersRef.child(slug).get();
  if(snap.exists()){se('addUserErr','User already exists');return;}
  await usersRef.child(slug).set({name,role,pass:btoa(pass),createdAt:Date.now()});
  document.getElementById('newUserName').value='';
  document.getElementById('newUserPass').value='';
  se('addUserErr','');
  toast(`Added: ${name} as ${role}`,'ok');
  await pushFeed(`${currentUser.name} added "${name}" (${role})`);
}

async function changeRole(slug,name,role){
  const decoded=name.replace(/&apos;/g,"'");
  await usersRef.child(slug).update({role});
  toast(`${decoded} is now ${role}`,'ok');
}

async function removeUser(slug,name){
  const decoded=name.replace(/&apos;/g,"'");
  if(!confirm(`Remove ${decoded} from the team?`))return;
  await usersRef.child(slug).remove();
  toast(`Removed: ${decoded}`,'err');
}

function setSyncBadge(type,text){
  const el=document.getElementById('syncBadge');
  el.className='sync-badge sb-'+type;
  document.getElementById('syncTxt').textContent=text;
}

function toast(msg,type='ok'){
  const wrap=document.getElementById('toastWrap');
  const t=document.createElement('div');
  t.className='toast '+type;
  t.textContent=msg;
  wrap.appendChild(t);
  setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>t.remove(),400);},3500);
}

document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){closeModal('leadModal');closeModal('usersModal');}
});

(function boot(){
  try{
    initFirebase(FIREBASE_CFG);
  }catch(e){
    show('setupScreen');
    se('setupErr','Firebase init failed: '+e.message);
    return;
  }
  // Probe the database to find out the real state instead of guessing.
  usersRef.get().then(snap=>{
    const hasUsers = snap.exists() && Object.keys(snap.val()||{}).length>0;
    if(hasUsers){
      const saved=loadUser();
      if(saved&&saved.name){
        document.getElementById('loginName').value=saved.name;
        document.getElementById('loginFooter').textContent=`🍼 Welcome back, ${saved.name}! 🍼`;
      }
      showLogin();
    } else {
      // Connected fine, but no users yet → create the first admin.
      show('setupScreen');
      se('setupErr','لا يوجد أي مستخدم بعد — سوِّ أول حساب أدمن.');
    }
  }).catch(e=>{
    // The ONLY way we land here is Firebase rejecting the read.
    show('setupScreen');
    const denied=/permission|denied/i.test(e.message||'');
    se('setupErr', denied
      ? '⚠️ قاعدة البيانات رافضة القراءة (Permission denied). روح Firebase Console → Realtime Database → Rules، خلّيها {".read":true,".write":true} واضغط Publish، بعدين Refresh.'
      : ('Database error: '+e.message));
  });
})();
</script>
